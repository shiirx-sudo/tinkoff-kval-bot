# ─── T-Invest API ────────────────────────────────────────────
# Только read-only токен. Full-access токен не используется.
TINKOFF_READ_TOKEN=your_readonly_token_here

# ─── Режим работы ────────────────────────────────────────────
# false = только чтение и расчёт, торговые заявки не отправляются
LIVE_ENABLED=false

# ─── Квал-цели (Т-Инвестиции, 2026) ─────────────────────────
# Стандартный порог по обороту
KVAL_TARGET_TURNOVER=6000000

# Порог при наличии профильного экономического образования
KVAL_TARGET_TURNOVER_WITH_ECON_EDU=4000000

# Буфер сверх цели (защита от погрешностей расчёта)
SAFETY_BUFFER_TURNOVER=100000

# ── Telegram read-only уведомления (мониторинг, БЕЗ заявок) ──────────────────
# Уведомления выключены по умолчанию. Токен НЕ логируется.
TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_MIN_INTERVAL_MINUTES=60
TELEGRAM_DAILY_SUMMARY_ENABLED=true
TELEGRAM_DAILY_SUMMARY_HOUR=10
TELEGRAM_STATUS_CHANGE_ONLY=true

# ── Balance-adaptive execution sizing (read-only расчёт) ─────────────────────
TINVEST_TARIFF=trader
EXECUTION_SIZE_MODE=balance
EXECUTION_BALANCE_UTILIZATION_PCT=0.80
EXECUTION_MIN_CASH_RESERVE_RUB=5000
EXECUTION_MAX_SIDE_NOTIONAL_RUB=0
EXECUTION_MIN_MONTHLY_ACTIONS=4
# Практический лимит действий в месяц (0 = выключено)
EXECUTION_MAX_MONTHLY_ACTIONS=40
KVAL_MIN_TOTAL_TRADES=41
KVAL_TARGET_TOTAL_TRADES=48
