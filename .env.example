# ─── T-Invest API ────────────────────────────────────────────
# Только read-only токен. Full-access токен не используется.
TINKOFF_READ_TOKEN=your_readonly_token_here

# ─── Режим работы ────────────────────────────────────────────
# false = только чтение и расчёт, торговые заявки не отправляются
LIVE_ENABLED=false

# ─── Квал-цели (Т-Инвестиции, 2026) ─────────────────────────
# Стандартный порог по обороту
KVAL_TARGET_TURNOVER=6000000

# Порог при наличии профильного экономического образования
KVAL_TARGET_TURNOVER_WITH_ECON_EDU=4000000

# Буфер сверх цели (защита от погрешностей расчёта)
SAFETY_BUFFER_TURNOVER=100000

# ── Telegram read-only уведомления (мониторинг, БЕЗ заявок) ──────────────────
# Уведомления выключены по умолчанию. Токен НЕ логируется.
TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_MIN_INTERVAL_MINUTES=60
TELEGRAM_DAILY_SUMMARY_ENABLED=true
TELEGRAM_DAILY_SUMMARY_HOUR=10
TELEGRAM_STATUS_CHANGE_ONLY=true

# ── Balance-adaptive execution sizing (read-only расчёт) ─────────────────────
TINVEST_TARIFF=trader
EXECUTION_SIZE_MODE=balance
EXECUTION_BALANCE_UTILIZATION_PCT=0.80
EXECUTION_MIN_CASH_RESERVE_RUB=5000
EXECUTION_MAX_SIDE_NOTIONAL_RUB=0
EXECUTION_MIN_MONTHLY_ACTIONS=4
# Практический лимит действий в месяц (0 = выключено)
EXECUTION_MAX_MONTHLY_ACTIONS=40
KVAL_MIN_TOTAL_TRADES=41
KVAL_TARGET_TOTAL_TRADES=48

# ── Стратегия сигналов trend_signal_v1 (read-only уведомления, БЕЗ заявок) ───
SIGNALS_ENABLED=false
SIGNALS_NOTIFY_TELEGRAM=true
SIGNALS_STRATEGY=trend_signal_v1
SIGNALS_WATCHLIST=LQDT
SIGNALS_ALLOWED_CLASS_CODES=TQBR,TQTF
SIGNALS_DEFAULT_CLASS_CODE=TQBR
SIGNALS_CLASS_CODE_PRIORITY=TQBR,TQTF,SPBRU
SIGNALS_TIMEFRAME=day
SIGNALS_LOOKBACK_DAYS=260
SIGNALS_MIN_SCORE=70
SIGNALS_NOTIFY_ON_HOLD=false
SIGNALS_SELL_ONLY_IF_HELD=true
SIGNALS_INCLUDE_PORTFOLIO_STATE=true
SIGNALS_FUNDAMENTAL_FILTER_ENABLED=false
SIGNALS_FUNDAMENTAL_FILTER_PATH=data/config/fundamental_filter.yaml
SIGNALS_REQUIRE_FUNDAMENTAL_PASS=false
SIGNALS_DEDUP_HOURS=12
SIGNALS_MAX_PER_RUN=10
SIGNALS_SPREAD_BPS_LIMIT=10
SIGNALS_MIN_DAILY_VALUE_RUB=10000000
SIGNALS_ATR_PERIOD=14
SIGNALS_RSI_PERIOD=14
SIGNALS_FAST_EMA=20
SIGNALS_MID_EMA=50
SIGNALS_SLOW_EMA=200
SIGNALS_STOP_ATR_MULTIPLIER=2.0
SIGNALS_TAKE_PROFIT_R_MULTIPLIER=2.0

# ── Income engine (read-only доходная аналитика, БЕЗ заявок) ─────────────────
INCOME_ENGINE_ENABLED=false
INCOME_TARGET_MONTHLY_RUB=0
INCOME_HORIZON_MONTHS=12
INCOME_CONFIG_PATH=data/config/income_engine.yaml
INCOME_ASSUME_TAX_RATE_PCT=13
INCOME_MONEY_MARKET_YIELD_PCT=0
INCOME_INCLUDE_UNKNOWN=false
# ── Income engine: автоматические read-only источники (T-Invest API) ─────────
# manual YAML остаётся как override/fallback; основной источник — официальный
# read-only API. Заявки не отправляются. История/trailing — оценка, не гарантия.
INCOME_AUTO_FETCH_ENABLED=true
INCOME_DIVIDEND_LOOKBACK_MONTHS=24
INCOME_DIVIDEND_TRAILING_MONTHS=12
INCOME_MM_TRAILING_DAYS=30
INCOME_USE_TRAILING_DIVIDENDS=true
INCOME_USE_KNOWN_FUTURE_DIVIDENDS=true
INCOME_USE_BOND_COUPONS=true
# ── Income quality policy v1 (conservative income mode, read-only) ───────────
# Отделяет надёжный доход (объявленные выплаты) от оценочного/переменного/
# ручного/разового. base income — для базового плана; estimate/excluded — нет.
INCOME_POLICY_ENABLED=true
INCOME_POLICY_TRAILING_YIELD_CAP_PCT=15
INCOME_POLICY_MM_HAIRCUT_PCT=20
INCOME_POLICY_USE_TRAILING_DIVIDENDS_IN_BASE=false
INCOME_POLICY_USE_MANUAL_DIVIDENDS_IN_BASE=false
INCOME_POLICY_USE_MANUAL_MM_IN_BASE=true
# ── Target portfolio v1 (read-only план целевого доходного портфеля) ─────────
# Аналитика и план докупки под целевой доход. Заявок нет, портфель не меняется.
TARGET_MAX_POSITION_PCT=25
TARGET_MAX_ISSUER_PCT=30
TARGET_MAX_MONEY_MARKET_PCT=40
TARGET_EXCLUDE_UNKNOWN=true
TARGET_INCLUDE_ESTIMATED=false
TARGET_INCLUDE_VARIABLE=true
TARGET_MIN_POLICY_BUCKET=income_variable
TARGET_CASH_RESERVE_RUB=5000
TARGET_MIN_ORDER_PLAN_RUB=1000
